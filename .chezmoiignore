.config/fish/conf.d/01-session-path.fish

# Secret env files holding bot tokens — never track (org policy: never commit .env).
# The agent-deck conductor bridge sources TELEGRAM_BOT_TOKEN from such a .env.
.env
**/.env
.agent-deck/**/.env
.local/share/agent-deck/**/.env

